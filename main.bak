import webview
from simulator import DeviceSimulator

# 绑定 Python API
class JsApi:
    def openPhone(self):
        startPhone()

def startPhone():
    phoneWindow = webview.create_window(
        title="IPHONE_13",
        url="https://www.deviceinfo.me/",
        width=375,
        height=667,
        resizable=False,
        confirm_close=True,
        text_select=True,
    )
    # simulator = DeviceSimulator(phoneWindow)

def evaluate_js(window):
    device_profiles = {
        "iPhone 14 Pro": {
            "user_agent": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
            "screen": {"width": 393, "height": 852, "pixel_ratio": 3},
        },
        "Samsung Galaxy S22 Ultra": {
            "user_agent": "Mozilla/5.0 (Linux; Android 12; SM-S908B) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Mobile Safari/537.36",
            "screen": {"width": 384, "height": 854, "pixel_ratio": 3.5},
        },
        "Desktop Chrome": {
            "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36",
            "screen": {"width": 1200, "height": 800, "pixel_ratio": 1},
        }
    }
    # 选择要模拟的设备
    agent = device_profiles["iPhone 14 Pro"]["user_agent"]
    result = window.evaluate_js(
        f"""
         Object.defineProperty(screen, 'devicePixelRatio', {{
            value: 3,
            writable: false
        }});
          // 覆盖screen对象属性
        Object.defineProperty(screen, 'width', {{
            value: 375,
            writable: false
        }});
        
        Object.defineProperty(screen, 'height', {{
            value: 667,
            writable: false
        }});
        
        Object.defineProperty(navigator, 'userAgent', {{
            value: '{agent}',
            writable: false
        }});
        // 返回用户代理
        'User agent:' + navigator.userAgent;
        """
    )

    print(result)

